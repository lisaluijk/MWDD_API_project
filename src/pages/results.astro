---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Results</title>
	</head>
	<body>
		<div class="windowBox px-corners-m">
			<span class="px-corners-s">your_personal_playlist.mp3</span>
			<div class="px-corners-s content">
				<h1>Here is your record playlist:</h1>

				<p>Your chosen genres: {chosenGenres}</p>
				<p>The amount of records you wanted: {time}</p>

				<ul id="recordList"></ul>
			</div>
		</div>

		<script define:vars={{ records, url, chosenGenres, time, filtered }}>
			// @ts-nocheck
			// const chosenGenres = genres;
			/*
			console.log("hier komen masterdata")
			console.log(masterData)*/

			const recordsList = document.querySelector("#recordList");
			// const recordsListItems =
			// 	document.querySelectorAll("#recordList > *");
			// console.log(recordsListItems);

			let displayRecords = records;

			const list = document.querySelector("#recordList");

			// aantal platen laten zien omzetten van string naar integer
			recordAmount = parseInt(time);

			/*
			if (
				typeof recordAmount === "string" ||
				recordAmount instanceof String
			) {
				console.log("jup issa stirng jammerdan");
			} else {
				console.log(
					"whoop we kunnen door jippie we could use a win :')",
				);
			}
			*/

			// shuffelen door telkens twee records met elkaar te swappen en een soort deconstruct iets om code lines te besparen.
			function shuffle(arr) {
				// ... = spread operator?
				// used to make a copy otherwise you are referencing to the same array with different variables
				const copy = [...arr];

				// ga door de array heen en wissel telkens een record met een andere record
				for (let i = copy.length - 1; i > 0; i--) {
					const j = Math.floor(Math.random() * (i + 1));

					// array destructuring assignment(?) basically scheelt lines of code omdat je het kan swappen terwijl het wel op elkaar berust zeg maar, beetje de css vibes met dat swappen
					[copy[i], copy[j]] = [copy[j], copy[i]];
				}

				return copy;
			}

			const shuffledRecords = shuffle(filtered);
			console.log(shuffledRecords);

			const selectedRecords = shuffledRecords.slice(0, recordAmount);

			selectedRecords.forEach((record) => {
				const li = document.createElement("li");

				const img = document.createElement("img");
				img.src = record.basic_information.cover_image;
				img.alt = record.basic_information.title;

				const title = document.createElement("p");
				title.textContent = record.basic_information.title;

				li.appendChild(img);
				li.appendChild(title);

				list.appendChild(li);
			});

			// console.log(displayRecords);

			// get track duration
			// const masterURL = record.basic_information.master_url;
			// console.log(masterURL);

			// async function getTrackDuration() {
			// 	const masterResponse = await fetch(masterURL);
			// 	const masterData = await masterResponse.json();
			// 	const masterInformation = masterData.releases;
			// }

			// getTrackDuration();
			// console.log(masterInformation)

			// carrousel code
			// recordslist is container and recordslistitems are items
			// source gpt

			const recordsListItems =
				document.querySelectorAll("#recordList > *");
			console.log(recordsListItems);

			function updateActive() {
				const center =
					recordsList.scrollLeft + recordsList.offsetWidth / 2;

				recordsListItems.forEach((item) => {
					const itemCenter = item.offsetLeft + item.offsetWidth / 2;

					if (Math.abs(center - itemCenter) < item.offsetWidth / 2) {
						item.classList.add("is-active");
					} else {
						item.classList.remove("is-active");
					}
					// eigen code
					if (itemCenter > center) {
						item.classList.add("right-of-center");
					} else {
						item.classList.remove("right-of-center");
					}

					if (itemCenter < center) {
						item.classList.add("left-of-center");
					} else {
						item.classList.remove("left-of-center");
					}
				});
			}

			updateActive();
			recordsList.addEventListener("scroll", updateActive);
		</script>
	</body>
</html>
