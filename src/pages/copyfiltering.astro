			// get filter buttons!!!
			// get data to browser
			// const displayRecords = JSON.parse(`{JSON.stringify(records)}`);
			const displayRecords = records;


			// change buttoncontainer to fieldset
			const buttonContainer = document.querySelector("#genreButtons");
			const list = document.querySelector("#recordList");

			// get genres
			const genres = [
				...new Set(
					displayRecords.flatMap(
						(record) => record.basic_information.genres || [],
					),
				),
			];

			// create filter buttons
			genres.forEach((genre) => {
				const button = document.createElement("button");
				button.textContent = genre;

				button.addEventListener("click", () => {
					renderList(genre);
				});

				console.log(genre)

				buttonContainer.appendChild(button);
			});

			// filter function
			// change function name and list
			function renderList(selectedGenre) {
				list.innerHTML = "";

				const filtered = displayRecords.filter((record) =>
					record.basic_information.genres?.includes(selectedGenre),
				);

				filtered.forEach((record) => {
					const li = document.createElement("li");

					const img = document.createElement("img");
					img.src = record.basic_information.cover_image;
					img.alt = record.basic_information.title;

					const title = document.createElement("p");
					title.textContent = record.basic_information.title;

					li.appendChild(img);
					li.appendChild(title);

					list.appendChild(li);
				});
			}

			//  show all records already
			renderList(genres[0]);
		</script>
