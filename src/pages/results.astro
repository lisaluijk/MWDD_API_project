---
// @ts-nocheck
import "../styles/style.css";

export const prerender = false;

const discogsKey = import.meta.env.DISCOG_TOKEN;
const userName = "lisa_luijk";
const discogsURL = `https://api.discogs.com/users/${userName}/collection/folders/0/releases?token=${discogsKey}&per_page=100&sort=artist`;
const response = await fetch(discogsURL);
const data = await response.json();
const records = data.releases;

// source gpt
const url = Astro.url;
// const url = document.url;

// get data from url
const chosenGenres = url.searchParams.getAll("genres");
const time = url.searchParams.get("listenTime");

// filtering on genres
const filtered = records.filter((record) => {
	const recordGenres = record.basic_information.genres || [];
	return chosenGenres.some((g) => recordGenres.includes(g));
});

